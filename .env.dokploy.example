# ---------------------------------------------------------------------------
# BERN OKULEKA - Bagisto production environment for Dokploy
# Copy this file into Dokploy > Application > Environment and replace every
# CHANGE_ME_* value before the first deploy.
# ---------------------------------------------------------------------------

# Application
APP_NAME="BERN OKULEKA"
APP_ENV=production
APP_KEY=CHANGE_ME_GENERATE_WITH_php_artisan_key_generate_show
APP_DEBUG=false
APP_DEBUG_ALLOWED_IPS=
APP_URL=https://CHANGE_ME_DOMAIN
APP_ADMIN_URL=admin
APP_TIMEZONE=Africa/Lagos
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_CURRENCY=AOA
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# External MySQL created separately in Dokploy
# DB_HOST must be only the internal hostname, never a full mysql:// URL.
DB_CONNECTION=mysql
DB_HOST=CHANGE_ME_DOKPLOY_MYSQL_INTERNAL_HOST
DB_PORT=3306
DB_DATABASE=bagisto
DB_USERNAME=bagisto
DB_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Sessions, cache, and queues
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=bern_okuleka_cache
QUEUE_CONNECTION=database

# External Redis created separately in Dokploy
REDIS_CLIENT=phpredis
REDIS_HOST=CHANGE_ME_DOKPLOY_REDIS_INTERNAL_HOST
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DATABASE=2
REDIS_PREFIX=bern_okuleka_database_

# Elasticsearch is kept inside docker-compose.dokploy.yml
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASS=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CLOUD_ID=
ELASTICSEARCH_INDEX_PREFIX=bern_okuleka_

# Full page cache
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_DRIVER=file
RESPONSE_CACHE_LIFETIME=604800

# Files
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Email
# Keep bagisto-dynamic-smtp so Admin > Configuration > Emails > SMTP controls delivery.
# These SMTP values are production fallbacks and match ZeptoMail/ZohoMail.
MAIL_MAILER=bagisto-dynamic-smtp
MAIL_HOST=smtp.zeptomail.com
MAIL_PORT=465
MAIL_USERNAME=emailapikey
MAIL_PASSWORD=CHANGE_ME_ZEPTOMAIL_API_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_EHLO_DOMAIN=email.bernokuleka.com
MAIL_FROM_ADDRESS=noreply@email.bernokuleka.com
MAIL_FROM_NAME="BERN OKULEKA"
ADMIN_MAIL_ADDRESS=CHANGE_ME_ADMIN_EMAIL
ADMIN_MAIL_NAME="BERN OKULEKA"
CONTACT_MAIL_ADDRESS=CHANGE_ME_CONTACT_EMAIL
CONTACT_MAIL_NAME="BERN OKULEKA"

# Unitel Money Gateway
# Admin configuration has priority; keep disabled here unless you want env fallback.
# Callback URL format: ${APP_URL}/unitel-money/callback/${UNITEL_MONEY_CALLBACK_SECRET}
UNITEL_MONEY_ACTIVE=false
UNITEL_MONEY_SANDBOX=true
UNITEL_MONEY_CLIENT_ID=
UNITEL_MONEY_CLIENT_SECRET=
UNITEL_MONEY_MERCHANT_ID=
UNITEL_MONEY_SERVICE_CODE=
UNITEL_MONEY_SANDBOX_BASE_URL=
UNITEL_MONEY_PRODUCTION_BASE_URL=
UNITEL_MONEY_OAUTH_PATH=/oauth2/token
UNITEL_MONEY_BUY_GOODS_PATH=/buyGoods_async
UNITEL_MONEY_QUERY_STATUS_PATH=/queryTransactionStatus
UNITEL_MONEY_CALLBACK_SECRET=CHANGE_ME_LONG_RANDOM_CALLBACK_SECRET
UNITEL_MONEY_ALLOWED_IPS=

# EMIS / Multicaixa Express Gateway
# Admin configuration has priority; keep disabled here unless you want env fallback.
EMIS_PAYMENT_ACTIVE=false
EMIS_PAYMENT_REFERENCE_PREFIX=BERNO
EMIS_PAYMENT_FRAME_TOKEN=
EMIS_PAYMENT_TERMINAL_ID=
EMIS_PAYMENT_MOBILE_MODE=PAYMENT
EMIS_PAYMENT_QRCODE_MODE=PAYMENT
EMIS_PAYMENT_CARD_MODE=DISABLED
EMIS_PAYMENT_ENDPOINT=https://pagamentonline.emis.co.ao/online-payment-gateway/portal/frameToken
EMIS_PAYMENT_FRAME_HOST=https://pagamentonline.emis.co.ao/online-payment-gateway/portal/frame?token=

# Optional external services
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_REQUEST_TIMEOUT=30
FIXER_API_KEY=
EXCHANGE_RATES_API_KEY=

# Social login, only fill if enabled in Bagisto admin
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# Dokploy startup controls
RUN_MIGRATIONS=true
RUN_INDEXERS=false
