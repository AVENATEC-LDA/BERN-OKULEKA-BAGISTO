{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "lib": ["ES2022", "DOM"],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@fixtures/*": ["fixtures/*"],
            "@pages/*": ["pages/*"],
            "@utils/*": ["utils/*"],
            "@data/*": ["data/*"]
        },
        "types": ["node"]
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "playwright-report", "test-results", ".state"]
}
